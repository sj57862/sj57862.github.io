<%- include('../partials/site-start', { title: typeof title !== 'undefined' ? title : 'Pizza' }) %>

<div class="card p-3 rounded-3 bg-white">
  <h1>Pizza</h1>

  <div class="table-responsive rounded-3 overflow-hidden">
    <table class="table mb-0">
      <tbody>
        <tr>
          <th>Id</th>
          <td><%= pizza.id %></td>
        </tr>
        <tr>
          <th>Name</th>
          <td><%= pizza.name %></td>
        </tr>
        <tr>
          <th>Price</th>
          <td><%= pizza.price %></td>
        </tr>
        <tr>
          <th>Description</th>
          <td><%= pizza.description %></td>
        </tr>
      </tbody>
    </table>
  </div>

  <div class="mt-3">
    <a href="/pizza" class="btn btn-secondary btn-sm">back to list</a>
    <a href="/pizza/<%= pizza.id %>/edit" class="btn btn-outline-primary btn-sm ms-2">edit</a>
    <%- include('_delete_form') %>
  </div>
</div>

<%- include('../partials/site-end') %>
