```ejs
<div class="form-group">
    <label for="name">Pizza name</label>
    <input
            type="text"
            id="name"
            name="pizza[name]"
            value="<%= pizza ? pizza.name : '' %>"
    >
</div>

<div class="form-group">
    <label for="price">Price</label>
    <input
            type="number"
            id="price"
            name="pizza[price]"
            value="<%= pizza ? pizza.price : '' %>"
    >
</div>

<div class="form-group">
    <label for="description">Description</label>
    <textarea
            id="description"
            name="pizza[description]"
    ><%= pizza ? (pizza.description || '') : '' %></textarea>
</div>

<div class="form-group">
    <label></label>
    <input type="submit" value="Submit">
</div>
```
