{
    "name": "symfony/ux-turbo",
    "type": "symfony-bundle",
    "description": "Hotwire Turbo integration for Symfony",
    "keywords": [
        "symfony-ux",
        "turbo",
        "hotwire",
        "javascript",
        "turbo-stream",
        "mercure"
    ],
    "homepage": "https://symfony.com",
    "license": "MIT",
    "authors": [
        {
            "name": "Kévin Dunglas",
            "email": "kevin@dunglas.fr"
        },
        {
            "name": "Symfony Community",
            "homepage": "https://symfony.com/contributors"
        }
    ],
    "autoload": {
        "psr-4": {
            "Symfony\\UX\\Turbo\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Symfony\\UX\\Turbo\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.4",
        "symfony/stimulus-bundle": "^2.9.1|^3.0"
    },
    "require-dev": {
        "doctrine/doctrine-bundle": "^2.14|^3.0|^4.0",
        "doctrine/orm": "^2.8|^3.0",
        "phpstan/phpstan": "^2.1.17",
        "symfony/asset-mapper": "^7.4|^8.0",
        "symfony/browser-kit": "^7.4|^8.0",
        "symfony/debug-bundle": "^7.4|^8.0",
        "symfony/form": "^7.4|^8.0",
        "symfony/framework-bundle": "^7.4|^8.0",
        "symfony/mercure-bundle": "^0.3.7|^0.4.1",
        "symfony/messenger": "^7.4|^8.0",
        "phpunit/phpunit": "^11.1|^12.0",
        "symfony/property-access": "^7.4|^8.0",
        "symfony/security-core": "^7.4|^8.0",
        "symfony/stopwatch": "^7.4|^8.0",
        "symfony/ux-twig-component": "^2.21|^3.0",
        "symfony/twig-bundle": "^7.4|^8.0",
        "symfony/web-profiler-bundle": "^7.4|^8.0",
        "symfony/expression-language": "^7.4|^8.0"
    },
    "conflict": {
        "symfony/flex": "<1.13"
    },
    "extra": {
        "thanks": {
            "name": "symfony/ux",
            "url": "https://github.com/symfony/ux"
        }
    },
    "minimum-stability": "dev",
    "config": {
        "allow-plugins": {
            "composer/package-versions-deprecated": true
        }
    }
}
