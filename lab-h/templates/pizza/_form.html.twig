{{ form_start(form) }}
    <div class="row g-3">
        <div class="col-12">
            {{ form_label(form.name, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.name, {attr: {class: 'form-control' ~ (form.name.vars.errors|length ? ' is-invalid' : ''), autofocus: 'autofocus', placeholder: 'np. Margherita', maxlength: '255'}}) }}
            {% if form.name.vars.errors|length %}
                <div class="invalid-feedback">
                    {{ form_errors(form.name) }}
                </div>
            {% endif %}
        </div>

        <div class="col-md-4 col-12">
            {{ form_label(form.price, null, {'label_attr': {'class': 'form-label'}}) }}
            <div class="input-group">
                {{ form_widget(form.price, {attr: {class: 'form-control' ~ (form.price.vars.errors|length ? ' is-invalid' : ''), type: 'number', step: '0.01', min: '0', placeholder: '0.00', 'aria-label': 'Price'}}) }}
                <span class="input-group-text">zł</span>
            </div>
            {% if form.price.vars.errors|length %}
                <div class="invalid-feedback">
                    {{ form_errors(form.price) }}
                </div>
            {% endif %}
        </div>

        <div class="col-12">
            {{ form_label(form.description, null, {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.description, {attr: {class: 'form-control' ~ (form.description.vars.errors|length ? ' is-invalid' : ''), rows: 3, placeholder: 'Krótki opis składników', maxlength: '1000'}}) }}
            {% if form.description.vars.errors|length %}
                <div class="invalid-feedback">
                    {{ form_errors(form.description) }}
                </div>
            {% endif %}
        </div>
    </div>

    <div class="mt-3">
        <button class="btn btn-primary">{{ button_label|default('Save') }}</button>
    </div>

    {{ form_widget(form) }}
    <button class="btn">{{ button_label|default('Save') }}</button>
{{ form_end(form) }}
